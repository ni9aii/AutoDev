# AutoDev Pipeline — Environment Variables

# GitHub Personal Access Token (required for release and CI check)
# Needs 'repo' scope for private repos. ci-check also reads GITHUB_TOKEN.
GITHUB_TOKEN=ghp_your_token_here

# Root for dev-notes paths (optional; default: ~/obsidian-vault/dev-notes)
# Overridable per-run via --dev-notes-root.
DEV_NOTES_ROOT=/home/you/obsidian-vault/dev-notes
